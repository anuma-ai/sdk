    "@reverbia/portal": "1.0.0-next.20251112"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.87.2",
    "rimraf": "^6.1.0",
    "typedoc": "^0.28.14",
    "typedoc-plugin-frontmatter": "^1.3.0",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3"
