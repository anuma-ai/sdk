    "eval:vault": "tsx test/memory/longmemeval.ts --strategy vault",
    "eval:longmemeval": "tsx test/memory/longmemeval.ts",
    "eval:longmemeval:preload": "tsx test/memory/longmemeval.ts --preload",
    "api-report": "node scripts/api-extractor-run.mjs",
    "api-report:update": "node scripts/api-extractor-run.mjs --local",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "check-exports": "publint && attw --pack --ignore-rules no-resolution false-cjs",
    "check": "pnpm run lint && pnpm run knip && pnpm run format && pnpm run generate"
