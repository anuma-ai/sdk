  "scripts": {
    "spec": "openapi-ts && node scripts/patch-generated-client.mjs",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.mts",
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "docs": "typedoc",
    "generate": "pnpm run spec && pnpm run docs && tsx scripts/generate-schema-docs.ts",
    "e2e:tools": "vitest run --config vitest.e2e.config.mts",
    "e2e:compare": "tsx scripts/compare-app-gen-runs.ts",
    "perf:slides": "vitest run --config vitest.perf.config.mts",
    "eval:engine": "tsx test/memory/longmemeval.ts --strategy engine",
    "eval:vault": "tsx test/memory/longmemeval.ts --strategy vault",
    "eval:longmemeval": "tsx test/memory/longmemeval.ts",
    "eval:longmemeval:preload": "tsx test/memory/longmemeval.ts --preload",
    "eval:vault-search": "tsx test/memory/src/vault/benchmark.test.ts",
    "update-model-apis": "tsx scripts/update-model-apis.ts",
    "api-report": "node scripts/api-extractor-run.mjs",
    "api-report:update": "node scripts/api-extractor-run.mjs --local",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "check-exports": "publint && attw --pack --ignore-rules no-resolution false-cjs",
    "check": "pnpm run lint && pnpm run knip && pnpm run format && pnpm run generate",
    "eval:extraction": "tsx test/memory/src/extraction/benchmark.test.ts"
  },
