{
  "name": "Overview",
  "hidePageHeader": true,
  "hideBreadcrumbs": true,
  "textContentMappings": {
    "title.indexPage": "{projectName}",
    "title.memberPage": "{name}",
    "title.modulePage": "Overview"
  },
  "gitRevision": "main",
  "readme": "./README.md",
  "mergeReadme": true,
  "entryPoints": [
    "src/react/index.ts",
    "src/client/index.ts",
    "src/next/index.ts",
    "src/vercel/index.ts",
    "src/expo/index.ts"
  ],
  "indexFormat": "table",
  "entryFileName": "README.md",
  "parametersFormat": "table",
  "expandParameters": true,
  "expandObjects": true,
  "plugin": [
    "typedoc-plugin-markdown",
    "typedoc-plugin-frontmatter"
  ]
}